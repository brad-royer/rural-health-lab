# Secrets
.env
*.tfvars
!example.tfvars
*.pem
*.key

# Terraform / OpenTofu
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Ansible
*.retry

# Synthea generated output (can be large; regenerate from config)
synthea/output/
synthea/*.zip

# Synthea jar cache (downloaded by scripts/generate-synthea.sh; large binary,
# reproducible via SYNTHEA_VERSION pin — not committed)
synthea/.cache/

# Docker / runtime
**/data/
**/volumes/

# Hyper-V provisioning: generated SSH keypairs, rendered cloud-init
# user-data, and seed ISOs (regenerable via
# infra/hyperv/cloud-init/build-seed-iso.sh) plus downloaded install media
infra/hyperv/cloud-init/.generated/
infra/hyperv/**/*.iso

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
